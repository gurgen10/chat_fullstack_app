# Use 5433 when Postgres runs via repo docker-compose (host port avoids Windows PG on 5432).
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/chat_app?schema=public"
JWT_SECRET="change-me"
PORT=3000
UPLOAD_DIR="./uploads"
# Used to build password-reset links (logged by the server; wire email/SMTP for production).
FRONTEND_ORIGIN="http://localhost:5173"
# Set to "true" to include resetUrl/resetToken in API responses (avoid in production).
PASSWORD_RESET_DEBUG="false"
