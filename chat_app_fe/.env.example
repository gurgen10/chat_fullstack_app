# Optional. If unset while using `npm run dev`, the app calls `/api/*` and Vite
# proxies to Nest (see vite.config.ts). Default proxy target is http://127.0.0.1:3000.
# In Docker Compose the frontend sets API_UPSTREAM=http://backend:3000 (server-side only).
# For production or when the API is on another host/port in the browser, set:
# VITE_API_ORIGIN=http://localhost:3000
